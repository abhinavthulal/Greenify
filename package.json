{
  "name": "greenify-batch",
  "version": "1.0.0",
  "description": "Batch image processor - convert to green shades and remove white backgrounds",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && cp dist/index.html dist/404.html",
    "preview": "vite preview",
    "lint": "eslint src --ext .jsx,.js",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.38.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.46.0",
    "eslint-plugin-react": "^7.32.2",
    "gh-pages": "^6.3.0",
    "postcss": "^8.4.26",
    "tailwindcss": "^3.3.0",
    "vite": "^5.0.0"
  },
  "packageManager": "npm@11.3.0",
  "engines": {
    "node": ">=18.0.0"
  }
}
